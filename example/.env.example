# Copy to `.env` and fill in from https://dashboard.workos.com

WORKOS_CLIENT_ID=client_...
WORKOS_API_KEY=sk_test_...
WORKOS_REDIRECT_URI=http://localhost:4321/callback
WORKOS_COOKIE_PASSWORD=replace-with-a-secret-at-least-32-characters-long

