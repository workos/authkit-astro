{
  "name": "@workos/authkit-astro",
  "version": "0.1.0",
  "description": "Official WorkOS AuthKit SDK for Astro",
  "type": "module",
  "sideEffects": [
    "./dist/elements.js"
  ],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./elements": {
      "types": "./dist/elements.d.ts",
      "import": "./dist/elements.js"
    },
    "./components": {
      "types": "./components/index.d.ts",
      "import": "./components/index.js"
    },
    "./AuthState.astro": "./components/AuthState.astro",
    "./internal/shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./internal/middleware": "./dist/internal/middleware.js",
    "./internal/routes/login": "./dist/internal/routes/login.js",
    "./internal/routes/signup": "./dist/internal/routes/signup.js",
    "./internal/routes/callback": "./dist/internal/routes/callback.js",
    "./internal/routes/logout": "./dist/internal/routes/logout.js",
    "./internal/routes/me": "./dist/internal/routes/me.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "components",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "example"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "workos",
    "authkit",
    "astro",
    "astro-integration",
    "withastro",
    "authentication",
    "auth"
  ],
  "author": "WorkOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/workos/authkit-astro.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@workos-inc/node": "^10.0.0",
    "astro": "^6.0.0 || ^7.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@workos/authkit-session": "^0.5.4",
    "nanostores": "^1.3.0",
    "path-to-regexp": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.8",
    "@workos-inc/node": "^10.2.0",
    "astro": "^7.0.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "react": "^19.2.7",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
